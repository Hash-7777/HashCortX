{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "HashCortx capability set. Custom IPC commands (keychain, audit, fs, shell) are registered via invoke_handler and need no capability entry — only plugin-level JS APIs do.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-outer-position",
    "core:window:allow-set-position",
    "core:window:allow-inner-size",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "core:window:allow-show",
    "opener:default",
    "notification:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-delete",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open"
  ]
}
